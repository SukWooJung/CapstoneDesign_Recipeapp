<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#efefef"
    tools:context=".fragment.DetailFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <ImageButton
            android:id="@+id/close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right"
            android:backgroundTint="#efefef"
            app:srcCompat="@android:drawable/ic_menu_close_clear_cancel" />

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:layout_gravity="center"
            android:text="º상세조건º"
            android:textSize="23dp"
            android:textStyle="bold" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/cook_level"
                android:layout_width="108dp"
                android:layout_height="54dp"
                android:layout_marginStart="16dp"
                android:layout_marginLeft="16dp"
                android:gravity="center_vertical"
                android:text="요리수준"
                android:textSize="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0" />

            <RadioButton
                android:id="@+id/all_button"
                android:layout_width="114dp"
                android:layout_height="58dp"
                android:text="모두선택"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.888"

                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="74dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/top"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="30dp"
                android:layout_weight="1"
                android:text="상"
                android:textSize="25dp" />

            <Button
                android:id="@+id/middle"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="30dp"
                android:layout_weight="1"
                android:text="중"
                android:textSize="25dp" />

            <Button
                android:id="@+id/btm"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="30dp"
                android:layout_weight="1"
                android:text="하"
                android:textSize="25dp" />
        </LinearLayout>

        <View
            android:layout_width="360dp"
            android:layout_height="2dp"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            android:background="#dddddd" />


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="218dp">

            <TextView
                android:id="@+id/cook_type"
                android:layout_width="108dp"
                android:layout_height="54dp"
                android:layout_marginStart="16dp"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:text="요리종류"
                android:textSize="20dp"
                app:layout_constraintEnd_toStartOf="@+id/radioButton3"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/korea"
                android:layout_width="94dp"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:text="한식"
                android:textSize="25dp"
                app:layout_constraintEnd_toStartOf="@+id/china"
                app:layout_constraintHorizontal_bias="0.376"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cook_type" />

            <Button
                android:id="@+id/china"
                android:layout_width="94dp"
                android:layout_height="54dp"
                android:layout_marginEnd="40dp"
                android:layout_marginRight="40dp"
                android:layout_weight="1"
                android:text="중식"
                android:textSize="25dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/western"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.451" />

            <Button
                android:id="@+id/western"
                android:layout_width="94dp"
                android:layout_height="54dp"
                android:layout_marginEnd="24dp"
                android:layout_marginRight="24dp"
                android:layout_weight="1"
                android:text="양식"
                android:textSize="25dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/radioButton3"
                app:layout_constraintVertical_bias="0.078" />

            <RadioButton
                android:id="@+id/radioButton3"
                android:layout_width="108dp"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="8dp"
                android:layout_marginRight="8dp"
                android:text="모두선택"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/japan"
                android:layout_width="94dp"
                android:layout_height="54dp"
                android:text="일식"
                android:textSize="25dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@+id/korea"
                app:layout_constraintTop_toBottomOf="@+id/china"
                app:layout_constraintVertical_bias="0.555" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="360dp"
            android:layout_height="2dp"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp"
            android:background="#dddddd" />

        <TextView
            android:id="@+id/textView0"
            android:layout_width="390dp"
            android:layout_height="56dp"
            android:layout_gravity="bottom"
            android:layout_marginLeft="20dp"
            android:gravity="center_vertical"
            android:text="기타옵션"
            android:textSize="20dp" />

        <Button
            android:id="@+id/option_only"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:text="포함된 재료로만 검색"
            android:textSize="20dp" />

        <TextView
            android:id="@+id/textView5"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="" />

        <Button
            android:id="@+id/completion"
            android:layout_width="184dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:text="선택완료"
            android:textColor="#000000"
            android:textSize="25dp"
            app:backgroundTint="#00F4F0F0" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>